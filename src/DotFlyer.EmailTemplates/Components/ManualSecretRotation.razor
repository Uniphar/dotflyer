@namespace DotFlyer.EmailTemplates.Components
@using DotFlyer.Common.EmailTemplates
@inherits Microsoft.AspNetCore.Components.ComponentBase

@code {
    [Parameter]
    public required ManualSecretRotationModel Model { get; set; }
}

<BaseEmailLayout Environment="@Model.Environment">
    <div class="subject">Manual Secret Rotation Required</div>

    @if (!string.IsNullOrWhiteSpace(Model.Environment))
    {
        <p><strong>🔒 This secret is for the <span style="color:#dc2626; font-size:16px; font-weight:700;">@Model.Environment.ToUpperInvariant()</span> environment.</strong></p>
        <p class="email-muted">Ensure you apply this credential only to <b>@Model.Environment.ToUpperInvariant()</b> systems. Using it in the wrong environment may cause outages or security incidents.</p>
    }

    <div class="info-card">
        <p class="info-card-title">Rotation Details</p>

        <p><strong>Resource:</strong> @Model.ResourceName</p>
        <p><strong>Secret Name:</strong> @Model.SecretName</p>
        <p><strong>Old secret will be deleted at:</strong> @Model.OldSecretDeletionDateUtc.ToUniversalTime().ToString("G") UTC</p>
        
        <div class="mt-4">
            <p><strong>Key vaults affected:</strong></p>
            <ul>
                @foreach (var kv in Model.KeyVaults)
                {
                    <li>@kv</li>
                }
            </ul>

            @if (!string.IsNullOrEmpty(Model.PwPushUrl))
            {
                <p>
                    <strong>Password delivery link:</strong>
                    <a href="@Model.PwPushUrl">@Model.PwPushUrl</a><br />
                    <span class="email-muted">
                        Link valid for @Model.PwPushExpiresInDays days or @Model.PwPushExpiresAfterViews views (whichever comes first).
                    </span>
                </p>
            }
        </div>
    </div>

    <div class="mt-4">
        <p class="email-muted"><strong>⚠️ Important:</strong> Do not share this credential via email, chat, or any unencrypted channel. Use the password delivery link above. The old secret will be automatically deleted at the time indicated.</p>
    </div>
</BaseEmailLayout>